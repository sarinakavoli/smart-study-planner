rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ──────────────────────────────────────────────────────

    // Returns true if the current user has any active membership in the org.
    function isMember(orgId) {
      return exists(
        /databases/$(database)/documents/memberships/membership_$(request.auth.uid)_$(orgId)
      );
    }

    // Returns true if the current user is an active admin of the org.
    function isAdmin(orgId) {
      let mem = get(
        /databases/$(database)/documents/memberships/membership_$(request.auth.uid)_$(orgId)
      ).data;
      return mem.role == "admin" && mem.status == "active";
    }

    // ── Users ─────────────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if request.auth != null
        && request.auth.uid == userId;

      allow create: if request.auth != null
        && request.auth.uid == userId
        && request.resource.data.uid == request.auth.uid;

      allow update: if request.auth != null
        && request.auth.uid == userId
        && resource.data.uid == request.auth.uid
        && request.resource.data.uid == request.auth.uid;

      allow delete: if false;
    }

    // ── Organizations ─────────────────────────────────────────────────────────
    match /organizations/{organizationId} {

      // Members can read their organization.
      allow read: if request.auth != null
        && isMember(organizationId);

      // A signed-in user may create an organization they own.
      allow create: if request.auth != null
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.schemaVersion == 2
        && request.resource.data.source == "create_org_form";

      // Only active admins may update organization settings.
      allow update: if request.auth != null
        && isAdmin(organizationId);

      // Only active admins may delete their organization.
      allow delete: if request.auth != null
        && isAdmin(organizationId);
    }

    // ── Tasks ─────────────────────────────────────────────────────────────────
    match /tasks/{taskId} {
      allow read: if request.auth != null
        && request.auth.uid == resource.data.userId;

      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;

      allow update: if request.auth != null
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == request.auth.uid;

      allow delete: if request.auth != null
        && resource.data.userId == request.auth.uid;
    }

    // ── Categories ────────────────────────────────────────────────────────────
    match /categories/{categoryId} {
      allow read: if request.auth != null
        && request.auth.uid == resource.data.userId;

      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;

      allow update: if request.auth != null
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == request.auth.uid;

      allow delete: if request.auth != null
        && resource.data.userId == request.auth.uid;
    }

    // ── Invitations ───────────────────────────────────────────────────────────
    match /invitations/{inviteId} {

      // Admins can read invitations they created; invitees can read their own.
      allow read: if request.auth != null && (
        request.auth.uid == resource.data.invitedByUserId
        || request.auth.token.email == resource.data.invitedEmail
      );

      // Only active admins of the target org may create invitations.
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.invitedByUserId
        && isAdmin(request.resource.data.organizationId);

      // Only the invited email address may update (accept or decline).
      allow update: if request.auth != null
        && request.auth.token.email == resource.data.invitedEmail;

      allow delete: if false;
    }

    // ── UserIndex (debug only) ────────────────────────────────────────────────
    match /userIndex/{readableUserId} {
      allow read: if request.auth != null
        && request.auth.uid == resource.data.uid;

      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.uid;

      allow update: if request.auth != null
        && request.auth.uid == resource.data.uid
        && request.auth.uid == request.resource.data.uid;

      allow delete: if false;
    }

    // ── Memberships ───────────────────────────────────────────────────────────
    //
    // Document ID is always:  membership_<userId>_<organizationId>
    // This makes admin checks cheap: just an exists() or get() on a known path.
    //
    // A membership may be created in two ways:
    //   1. create_org_form — the organization creator writes their own admin
    //      membership immediately after creating the organization.
    //   2. invitation — an invited user writes their own membership after an
    //      admin has sent them an invitation.
    //
    match /memberships/{membershipId} {

      // A user may only read their own membership documents.
      allow read: if request.auth != null
        && request.auth.uid == resource.data.userId;

      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.userId
        // Enforce predictable ID format
        && membershipId == ("membership_" + request.auth.uid + "_" + request.resource.data.organizationId)
        && request.resource.data.status == "active"
        && request.resource.data.schemaVersion == 2
        && (
          // ── Path 1: org creator becomes their own admin ────────────────────
          (
            request.resource.data.source == "create_org_form"
            && request.resource.data.role == "admin"
            && get(/databases/$(database)/documents/organizations/$(request.resource.data.organizationId)).data.createdBy == request.auth.uid
          )
          ||
          // ── Path 2: invited user joins via invitation ──────────────────────
          // We verify the invitation matches this user's email and org.
          // Status is not re-checked here because the invitation is marked
          // "accepted" before this write (in acceptInvitation()), and a
          // membership can only be created once per user+org (deterministic ID).
          (
            request.resource.data.source == "invitation"
            && request.resource.data.invitationId != null
            && get(/databases/$(database)/documents/invitations/$(request.resource.data.invitationId)).data.invitedEmail == request.auth.token.email
            && get(/databases/$(database)/documents/invitations/$(request.resource.data.invitationId)).data.organizationId == request.resource.data.organizationId
            && get(/databases/$(database)/documents/invitations/$(request.resource.data.invitationId)).data.role == request.resource.data.role
          )
        );

      // A user may update their own membership (e.g. status changes).
      allow update: if request.auth != null
        && request.auth.uid == resource.data.userId
        && request.auth.uid == request.resource.data.userId;

      allow delete: if false;
    }

  }
}

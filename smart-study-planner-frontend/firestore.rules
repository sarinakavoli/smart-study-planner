rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── users collection ────────────────────────────────────────────────────
    // Each user may only read or write their own profile document.
    match /users/{userId} {
      allow read, write: if request.auth != null
                         && request.auth.uid == userId;
    }

    // ── tasks collection ────────────────────────────────────────────────────
    // A user may only access tasks where:
    //   - userId field matches their own UID, AND
    //   - organizationId field matches their personal org (org_<uid>)
    match /tasks/{taskId} {
      allow read, delete: if request.auth != null
                          && resource.data.userId == request.auth.uid
                          && resource.data.organizationId == ('org_' + request.auth.uid);

      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.organizationId == ('org_' + request.auth.uid);

      allow update: if request.auth != null
                    && resource.data.userId == request.auth.uid
                    && resource.data.organizationId == ('org_' + request.auth.uid)
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.organizationId == ('org_' + request.auth.uid);
    }

    // ── categories collection ────────────────────────────────────────────────
    // Same access model as tasks: userId and organizationId must both match.
    match /categories/{categoryId} {
      allow read, delete: if request.auth != null
                          && resource.data.userId == request.auth.uid
                          && resource.data.organizationId == ('org_' + request.auth.uid);

      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.organizationId == ('org_' + request.auth.uid);

      allow update: if request.auth != null
                    && resource.data.userId == request.auth.uid
                    && resource.data.organizationId == ('org_' + request.auth.uid)
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.organizationId == ('org_' + request.auth.uid);
    }

    // ── organizations collection ─────────────────────────────────────────────
    // A user may read an organization document only if their UID is listed in
    // the memberUids array (which includes the owner for personal orgs).
    // Only the owner may write to the organization document.
    match /organizations/{orgId} {
      allow read: if request.auth != null
                  && request.auth.uid in resource.data.memberUids;

      allow create: if request.auth != null
                    && request.resource.data.ownerId == request.auth.uid
                    && request.auth.uid in request.resource.data.memberUids;

      allow update, delete: if request.auth != null
                             && resource.data.ownerId == request.auth.uid;
    }

    // Deny everything else by default (implicit in Firestore, but stated
    // explicitly here for clarity).
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

# Copy this file to .env.local for local development overrides.
# .env.local is gitignored — never commit real values.
#
# In Replit, these are stored as Environment Variables (not secrets) because
# Firebase web config values are public project identifiers by design.
# See: https://firebase.google.com/docs/projects/api-keys

VITE_FIREBASE_API_KEY=your-firebase-api-key-here
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id
VITE_FIREBASE_APP_ID=your-app-id

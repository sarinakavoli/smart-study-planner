# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local

# Service account key — never commit this
scripts/serviceAccountKey.json

# Seed run manifests — local state files used by --undo-last
scripts/.last-seed-run-categories.json
scripts/.last-seed-run-tasks.json

# Seed count metadata — auto-updated after each seed run
scripts/.seed-counts.json

# Personal seed users config — keep account details off of version control
scripts/.seed-users

# Vitest JUnit report output
test-results

# CI test cache sentinel files
.test-cache
.seed-test-cache
.audit-tests-cache

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*

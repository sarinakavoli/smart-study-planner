modules = ["nodejs-20", "java-graalvm22.3", "web"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Backend"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Backend"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd smart-study-planner-backend && ./mvnw spring-boot:run"
waitForPort = 8080

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd smart-study-planner-frontend && npm run dev"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8080
externalPort = 8080

[deployment]
deploymentTarget = "vm"
run = ["bash", "-c", "cd smart-study-planner-backend && ./mvnw spring-boot:run & cd smart-study-planner-frontend && npm run preview -- --host 0.0.0.0 --port 5000"]
build = ["bash", "-c", "cd smart-study-planner-frontend && npm install && npm run build && cd ../smart-study-planner-backend && ./mvnw clean package -DskipTests"]

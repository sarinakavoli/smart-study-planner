modules = ["nodejs-20", "java-graalvm22.3", "web", "postgresql-16"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Backend"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Backend"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd smart-study-planner-backend && ./mvnw spring-boot:run"
waitForPort = 8080

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd smart-study-planner-frontend && npm run dev"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5001
externalPort = 3001

[[ports]]
localPort = 5002
externalPort = 3000

[[ports]]
localPort = 8080
externalPort = 8080

[deployment]
deploymentTarget = "vm"
run = ["java", "-jar", "smart-study-planner-backend/target/smart-study-planner-0.0.1-SNAPSHOT.jar", "--server.port=5000"]
build = ["sh", "smart-study-planner-backend/mvnw", "-f", "smart-study-planner-backend/pom.xml", "clean", "package", "-DskipTests"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 120000

[userenv]

[userenv.shared]
VITE_FIREBASE_API_KEY = "AIzaSyA7mXSBmMDTOFWS9UHdIlCh12RXdnptx7s"
VITE_FIREBASE_AUTH_DOMAIN = "dev-sarina.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID = "dev-sarina"
VITE_FIREBASE_STORAGE_BUCKET = "dev-sarina.firebasestorage.app"
VITE_FIREBASE_MESSAGING_SENDER_ID = "957894061134"
VITE_FIREBASE_APP_ID = "1:957894061134:web:384afd6eb88a91ce12a71f"
GCP_PROJECT_ID = "dev-sarina"
